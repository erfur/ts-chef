# Build inputs — not needed at runtime (esbuild bundles everything into dist/extension.js)
src/**
scripts/**
out/**
test/**

# Intermediate TypeScript compilation output — already bundled into dist/extension.js
dist/chef/**
dist/**/*.d.ts
dist/**/*.d.ts.map

# Node modules — bundled by esbuild, not shipped separately
node_modules/**

# TypeScript config
tsconfig*.json

# Source maps (comment out to keep maps for debugging)
**/*.map

# Dev & CI tooling
.vscode/**
.github/**
.claude/**
.superpowers/**
.gitignore
.eslintrc*
.prettierrc*
eslint.config.mjs
jest.config.js
typedoc.json
Makefile

# Generated reports — regenerated by CI, browsable via the repo
coverage/**
test-report/**

# Docs live in the repo; README links resolve to GitHub on the marketplace
docs/**

# Misc
report.md
*.vsix

# Assets: ship only the extension icon; demo media is referenced via the repo URL
assets/**
!assets/logo.jpg
